{
  "name": "mlm-dev-container",
  "dockerComposeFile": [
    "../docker-compose-dev.yml"
  ],
  "service": "mlm",
  "workspaceFolder": "/app",
  "forwardPorts": [8080],
  "postCreateCommand": "cd mlm && chmod +x mvnw && ./mvnw -DskipTests install", // Run Maven installation after container creation.
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
        "version": "latest",
        "ppa": "false"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": []
    }
  },
  // Map the linux user 'spring' to your VS Code user to fix permission errors
  "remoteUser": "root"
}